# =================================================================
# Sample environment file — copy to .env and fill in real values
# DO NOT commit the actual .env file (it is in .gitignore)
# =================================================================

# ── Main LLM (system agents) ───────────────────────────────────────
# OpenAI API key for gpt-4o-mini (default reasoning model)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: custom base URL for OpenAI-compatible APIs (Ollama, LM Studio, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# ── Embedding model (Sentence-BERT) ────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Matching threshold ─────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.5

# ── Memory store (Scenario C) ──────────────────────────────────────
# MEMORY_DIR=data/memory
MEMORY_TOP_K=5
MEMORY_MIN_SIMILARITY=0.3

# ── Orchestrator ───────────────────────────────────────────────────
MAX_REVISIONS=2

# ── LLM-as-a-Judge (independent auditor) ───────────────────────────
# IMPORTANT: use a DIFFERENT model family than the main LLM
# to avoid self-enhancement bias (cross-family rule).
#
# Default: DeepSeek (OpenAI-compatible API)
JUDGE_API_KEY=your-deepseek-key-here
JUDGE_BASE_URL=https://api.deepseek.com/v1
JUDGE_MODEL=deepseek-chat
JUDGE_TEMPERATURE=0.1
JUDGE_MAX_TOKENS=1500

# Alternative: Gemini (also OpenAI-compatible)
# JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# JUDGE_MODEL=gemini-2.5-flash

# ── Augmentation model (only for JD augmentation experiment) ───────
# Anthropic Claude Haiku — used to extend short job descriptions
# ANTHROPIC_API_KEY=sk-ant-your-key-here
